<script>
  // ── PLATE COUNTER ──
  let plateCount = 247;
  function changePlate(dir) {
    plateCount = Math.max(0, plateCount + dir);
    const el = document.getElementById('plateCount');
    el.style.transform = 'scale(1.15)';
    el.textContent = plateCount;
    setTimeout(() => el.style.transform = 'scale(1)', 200);
  }

  // ── DAY TOGGLE ──
  function toggleDay(el) {
    el.classList.toggle('active');
  }

  // ── MENU TABS ──
  const menuData = {
    Breakfast: [
      { emoji:'🥞', name:'Masala Oats & Poha', cal:'280 kcal', price:'₹45', tag:'Veg' },
      { emoji:'🍳', name:'Egg Bhurji & Toast', cal:'340 kcal', price:'₹60', tag:'Protein' },
      { emoji:'🥤', name:'Smoothie Bowl', cal:'220 kcal', price:'₹75', tag:'Healthy' },
      { emoji:'🫓', name:'Stuffed Paratha', cal:'390 kcal', price:'₹55', tag:'Quick' },
    ],
    Lunch: [
      { emoji:'🍛', name:'Dal Makhani Rice', cal:'520 kcal', price:'₹95', tag:'Veg' },
      { emoji:'🥗', name:'Chicken Buddha Bowl', cal:'480 kcal', price:'₹140', tag:'Non-Veg' },
      { emoji:'🫕', name:'Rajma Chawal', cal:'460 kcal', price:'₹80', tag:'Veg' },
      { emoji:'🍱', name:'Thali Special', cal:'600 kcal', price:'₹110', tag:'Full Meal' },
    ],
    Dinner: [
      { emoji:'🍝', name:'Pasta Arrabiata', cal:'420 kcal', price:'₹120', tag:'Italian' },
      { emoji:'🍲', name:'Paneer Butter Masala', cal:'510 kcal', price:'₹130', tag:'Veg' },
      { emoji:'🥘', name:'Grilled Fish Curry', cal:'380 kcal', price:'₹160', tag:'Non-Veg' },
      { emoji:'🫔', name:'Roti + Sabzi + Dal', cal:'440 kcal', price:'₹90', tag:'Homestyle' },
    ],
    Snacks: [
      { emoji:'☕', name:'Masala Chai + Biscuits', cal:'120 kcal', price:'₹20', tag:'Beverage' },
      { emoji:'🥪', name:'Veg Club Sandwich', cal:'280 kcal', price:'₹65', tag:'Snack' },
      { emoji:'🍦', name:'Kulfi Falooda', cal:'210 kcal', price:'₹50', tag:'Dessert' },
      { emoji:'🥜', name:'Sprout Chaat', cal:'160 kcal', price:'₹45', tag:'Healthy' },
    ],
  };

  const gradients = [
    'linear-gradient(135deg,#ffecd2,#fcb69f)',
    'linear-gradient(135deg,#a1c4fd,#c2e9fb)',
    'linear-gradient(135deg,#d4fc79,#96e6a1)',
    'linear-gradient(135deg,#f6d365,#fda085)',
  ];

  function setTab(btn, category) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const grid = document.getElementById('menuGrid');
    const items = menuData[category];
    grid.innerHTML = items.map((item, i) => `
      <div class="menu-item" style="--i:${i}; animation: fadeUp 0.4s ease ${i*0.07}s both;">
        <div class="menu-img-wrap" style="background:${gradients[i]}">
          ${item.emoji}
          <span class="menu-tag">${item.tag}</span>
        </div>
        <div class="menu-info">
          <div class="menu-name">${item.name}</div>
          <div class="menu-details">
            <div>
              <div class="menu-cals">${item.cal}</div>
              <div class="menu-price">${item.price}</div>
            </div>
            <button class="menu-add" onclick="addToCart(this)">+</button>
          </div>
        </div>
      </div>
    `).join('');
  }

  // ── ADD TO CART ──
  let cartCount = 0;
  function addToCart(btn) {
    cartCount++;
    btn.textContent = '✓';
    btn.style.background = '#10b981';
    setTimeout(() => {
      btn.textContent = '+';
      btn.style.background = 'var(--coral)';
    }, 1200);
  }

  // ── SCROLL REVEAL ──
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        // Stagger children
        entry.target.querySelectorAll('.stagger > *').forEach((child, i) => {
          child.style.transitionDelay = `${i * 0.08}s`;
        });
      }
    });
  }, { threshold: 0.12 });

  reveals.forEach(r => observer.observe(r));

  // ── AUTO INCREMENT PLATE COUNTER ──
  setInterval(() => {
    if (Math.random() > 0.6) {
      plateCount += Math.floor(Math.random() * 3) + 1;
      const el = document.getElementById('plateCount');
      if (el) {
        el.style.transition = 'transform 0.2s ease';
        el.style.transform = 'scale(1.08)';
        el.textContent = plateCount;
        setTimeout(() => el.style.transform = 'scale(1)', 200);
      }
    }
  }, 3000);
</script>
