<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MealMesh — Smart Mess Management & Meal Subscription</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --coral: #E63946;
    --coral-light: #ff6b6b;
    --coral-dark: #c1121f;
    --navy: #1D3557;
    --navy-light: #2d4f7f;
    --mint: #F1FAEE;
    --mint-dark: #d8f0e0;
    --white: #ffffff;
    --glass: rgba(255,255,255,0.15);
    --glass-border: rgba(255,255,255,0.25);
    --shadow-soft: 0 8px 32px rgba(29,53,87,0.10);
    --shadow-card: 0 4px 24px rgba(29,53,87,0.08);
    --shadow-hover: 0 16px 48px rgba(29,53,87,0.16);
    --radius: 20px;
    --radius-sm: 12px;
    --transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--mint);
    color: var(--navy);
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* ── GLASSMORPHISM NAV ── */
  nav {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1280px;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 100px;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 1000;
    box-shadow: 0 8px 32px rgba(29,53,87,0.10), 0 1px 0 rgba(255,255,255,0.8) inset;
    animation: navSlide 0.8s cubic-bezier(0.4,0,0.2,1) both;
  }

  @keyframes navSlide {
    from { opacity: 0; transform: translateX(-50%) translateY(-20px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logo-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--coral), #ff8f7e);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    box-shadow: 0 4px 12px rgba(230,57,70,0.35);
  }

  .nav-logo-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--navy);
    letter-spacing: -0.5px;
  }

  .nav-logo-text span { color: var(--coral); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--navy);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.2px;
    opacity: 0.75;
    transition: var(--transition);
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--coral);
    border-radius: 2px;
    transition: var(--transition);
  }

  .nav-links a:hover { opacity: 1; }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    background: var(--coral);
    color: white !important;
    padding: 10px 22px;
    border-radius: 100px;
    opacity: 1 !important;
    font-weight: 600 !important;
    font-size: 13px !important;
    box-shadow: 0 4px 16px rgba(230,57,70,0.35);
    transition: var(--transition) !important;
  }

  .nav-cta:hover {
    background: var(--coral-dark) !important;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(230,57,70,0.45) !important;
  }

  .nav-cta::after { display: none !important; }

  /* ── HERO SECTION ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 0;
    padding-top: 90px;
    position: relative;
    overflow: hidden;
  }

  /* Subtle gradient blob */
  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(230,57,70,0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    animation: blobPulse 8s ease-in-out infinite alternate;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -150px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(29,53,87,0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  @keyframes blobPulse {
    from { transform: scale(1) rotate(0deg); }
    to   { transform: scale(1.15) rotate(10deg); }
  }

  /* ── LEFT HERO PANEL ── */
  .hero-left {
    padding: 80px 60px 80px 80px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    animation: fadeUp 0.9s cubic-bezier(0.4,0,0.2,1) 0.2s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(230,57,70,0.08);
    border: 1px solid rgba(230,57,70,0.2);
    color: var(--coral);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    width: fit-content;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    background: var(--coral);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.08;
    letter-spacing: -2px;
  }

  .hero-title .highlight {
    color: var(--coral);
    position: relative;
    display: inline-block;
  }

  .hero-title .highlight::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 8px;
    background: rgba(230,57,70,0.15);
    border-radius: 4px;
    z-index: -1;
  }

  .hero-subtitle {
    font-size: 17px;
    color: var(--navy);
    opacity: 0.6;
    max-width: 440px;
    line-height: 1.7;
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--coral);
    color: white;
    padding: 16px 32px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 32px rgba(230,57,70,0.40);
    transition: var(--transition);
    letter-spacing: 0.2px;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: var(--coral-dark);
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(230,57,70,0.50);
  }

  .btn-primary svg { transition: transform 0.3s ease; }
  .btn-primary:hover svg { transform: translateX(4px); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: var(--navy);
    padding: 16px 28px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid rgba(29,53,87,0.15);
    transition: var(--transition);
    cursor: pointer;
  }

  .btn-secondary:hover {
    border-color: var(--navy);
    background: rgba(29,53,87,0.05);
    transform: translateY(-2px);
  }

  .hero-stats {
    display: flex;
    gap: 40px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-num {
    font-size: 28px;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -1px;
    font-family: 'Montserrat', sans-serif;
  }

  .stat-label {
    font-size: 12px;
    color: var(--navy);
    opacity: 0.5;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-divider {
    width: 1px;
    background: rgba(29,53,87,0.12);
    align-self: stretch;
  }

  /* ── RIGHT HERO PANEL ── */
  .hero-right {
    position: relative;
    padding: 60px 60px 60px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    animation: fadeUp 0.9s cubic-bezier(0.4,0,0.2,1) 0.4s both;
  }

  /* ── DASHBOARD CARD ── */
  .dashboard-card {
    background: white;
    border-radius: var(--radius);
    padding: 28px;
    box-shadow: var(--shadow-soft);
    border: 1px solid rgba(29,53,87,0.06);
    position: relative;
    overflow: hidden;
  }

  .dashboard-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--coral), #ff8f7e, var(--navy));
    border-radius: var(--radius) var(--radius) 0 0;
  }

  .dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .dashboard-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--navy);
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.5;
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(16,185,129,0.1);
    color: #059669;
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }

  /* MEAL TOGGLE */
  .meal-toggle-section { margin-bottom: 24px; }

  .toggle-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .toggle-label span {
    background: rgba(230,57,70,0.08);
    color: var(--coral);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 100px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .meal-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
  }

  .meal-day {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .day-label {
    font-size: 10px;
    font-weight: 600;
    color: var(--navy);
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .day-toggle {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 2px solid rgba(29,53,87,0.10);
    background: transparent;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    position: relative;
    overflow: hidden;
  }

  .day-toggle.active {
    background: var(--coral);
    border-color: var(--coral);
    color: white;
    box-shadow: 0 4px 12px rgba(230,57,70,0.35);
    transform: scale(1.05);
  }

  .day-toggle.active::after {
    content: '✓';
    font-size: 14px;
    font-weight: 700;
    color: white;
  }

  .day-toggle:not(.active)::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(29,53,87,0.15);
  }

  .day-toggle:hover:not(.active) {
    border-color: var(--coral);
    background: rgba(230,57,70,0.05);
    transform: scale(1.05);
  }

  /* PLATE COUNTER */
  .plate-counter {
    background: linear-gradient(135deg, var(--navy) 0%, #2d4f7f 100%);
    border-radius: var(--radius-sm);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .plate-counter::before {
    content: '';
    position: absolute;
    top: -30px;
    right: -30px;
    width: 120px;
    height: 120px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
  }

  .plate-counter::after {
    content: '';
    position: absolute;
    bottom: -50px;
    right: 40px;
    width: 100px;
    height: 100px;
    background: rgba(230,57,70,0.12);
    border-radius: 50%;
  }

  .counter-left { position: relative; z-index: 1; }

  .counter-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    opacity: 0.55;
    margin-bottom: 6px;
  }

  .counter-number {
    font-size: 48px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -2px;
    font-family: 'Montserrat', sans-serif;
    background: linear-gradient(135deg, #fff 60%, rgba(255,255,255,0.6));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .counter-sub {
    font-size: 12px;
    opacity: 0.5;
    margin-top: 4px;
  }

  .counter-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    position: relative;
    z-index: 1;
  }

  .counter-spark {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(16,185,129,0.2);
    color: #6ee7b7;
    font-size: 12px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 100px;
  }

  .counter-controls {
    display: flex;
    gap: 8px;
  }

  .ctrl-btn {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }

  .ctrl-btn.minus {
    background: rgba(255,255,255,0.12);
    color: white;
  }

  .ctrl-btn.plus {
    background: var(--coral);
    color: white;
    box-shadow: 0 4px 12px rgba(230,57,70,0.4);
  }

  .ctrl-btn:hover { transform: scale(1.1); }

  /* ── FOOD CARD ── */
  .food-showcase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .food-card {
    border-radius: var(--radius-sm);
    overflow: hidden;
    position: relative;
    aspect-ratio: 4/3;
    cursor: pointer;
    box-shadow: var(--shadow-card);
    transition: var(--transition);
    background: #f0f0f0;
  }

  .food-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: var(--shadow-hover);
  }

  .food-card.large {
    grid-column: span 2;
    aspect-ratio: 16/7;
  }

  .food-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Emoji-based food placeholders (since no images) */
  .food-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    position: relative;
  }

  .food-card:nth-child(1) .food-placeholder {
    background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  }
  .food-card:nth-child(2) .food-placeholder {
    background: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%);
  }
  .food-card:nth-child(3) .food-placeholder {
    background: linear-gradient(135deg, #d4fc79 0%, #96e6a1 100%);
  }

  .food-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(29,53,87,0.85));
    padding: 28px 16px 14px;
    color: white;
    transform: translateY(8px);
    transition: var(--transition);
  }

  .food-card:hover .food-overlay { transform: translateY(0); }

  .food-name {
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .food-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    opacity: 0.75;
  }

  .food-cal {
    background: rgba(230,57,70,0.8);
    padding: 2px 8px;
    border-radius: 100px;
    font-weight: 600;
  }

  /* ── FLOATING MINI CARD ── */
  .float-card {
    position: absolute;
    background: white;
    border-radius: 16px;
    padding: 14px 18px;
    box-shadow: 0 12px 40px rgba(29,53,87,0.15);
    border: 1px solid rgba(29,53,87,0.06);
    animation: float 6s ease-in-out infinite;
    z-index: 10;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .float-card-1 {
    top: 70px;
    right: -10px;
    animation-delay: -2s;
  }

  .float-card-2 {
    bottom: 80px;
    right: -20px;
    animation-delay: -4s;
  }

  .float-inner {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .float-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--coral), #ff8f7e);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    box-shadow: 0 4px 12px rgba(230,57,70,0.3);
  }

  .float-text { }
  .float-text strong { font-size: 14px; font-weight: 700; color: var(--navy); display: block; line-height: 1.2; }
  .float-text small { font-size: 11px; color: var(--navy); opacity: 0.5; font-weight: 500; }

  /* ── SECTION STYLES ── */
  section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 100px 60px;
    position: relative;
  }

  .section-eyebrow {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--coral);
    margin-bottom: 14px;
  }

  .section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .section-sub {
    font-size: 17px;
    color: var(--navy);
    opacity: 0.55;
    max-width: 520px;
    line-height: 1.7;
  }

  /* ── HOW IT WORKS ── */
  .how-section {
    background: white;
    border-radius: 32px;
    margin: 0 24px;
    max-width: unset;
    padding: 80px;
    box-shadow: var(--shadow-soft);
  }

  .how-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-top: 60px;
  }

  .how-step {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
  }

  .how-step:not(:last-child)::after {
    content: '→';
    position: absolute;
    top: 22px;
    right: -20px;
    font-size: 20px;
    color: var(--coral);
    opacity: 0.4;
    font-weight: 700;
  }

  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--coral), #ff8f7e);
    color: white;
    font-size: 20px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(230,57,70,0.35);
    font-family: 'Montserrat', sans-serif;
  }

  .step-icon {
    font-size: 32px;
  }

  .step-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.3px;
  }

  .step-desc {
    font-size: 14px;
    color: var(--navy);
    opacity: 0.55;
    line-height: 1.7;
